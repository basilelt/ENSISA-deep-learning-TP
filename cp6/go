#!/bin/bash
docker stop ia; docker rm ia
( cd ia; docker build --rm -t ia . )
docker stop nn; docker rm nn
( cd nn; mvn clean package -DskipTests; docker build --rm -t nn . )
echo "Beware if you try later with docker compose up"
echo "Before export this variable using :"
echo "export MODELS=`cd ..; pwd`"
export MODELS=`cd ..; pwd`
docker compose up
